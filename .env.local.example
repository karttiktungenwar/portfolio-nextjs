# Copy this file to .env.local and fill in your own values.
# .env.local is already in .gitignore — it will NEVER be committed to git
# or pushed to GitHub, so your Firebase credentials stay private.
#
# These come from a Firebase service account (Project settings ->
# Service accounts -> Generate new private key), NOT from the Firebase
# web app config. See README.md, Step 4, for exactly where to get each one.

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project-id.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----\n"
